{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "pagination": {
      "$ref": "#/definitions/PostSubmissionPagination"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "totalComments": {
          "type": "integer"
        },
        "sentiment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "supportive": {
              "type": "integer"
            },
            "objection": {
              "type": "integer"
            },
            "neutral": {
              "type": "integer"
            }
          }
        }
      },
      "required": ["totalComments", "sentiment"]
    },
    "comments": {
      "type": "array",
      "items": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "integer"
            },
            "sentiment": {
              "enum": ["objection", "neutral", "supportive"],
              "type": "string"
            },
            "comment": {
              "type": "string"
            },
            "receivedAt": {
              "format": "date-time",
              "type": ["string", "null"]
            }
          },
          "required": ["id", "sentiment", "comment", "receivedAt"]
        }
      ]
    }
  },
  "required": ["pagination", "summary", "comments"]
}
