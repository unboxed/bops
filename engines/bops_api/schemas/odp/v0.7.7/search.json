{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "page": {
          "type": "integer"
        },
        "results": {
          "type": "integer"
        },
        "from": {
          "type": "integer"
        },
        "to": {
          "type": "integer"
        },
        "total_pages": {
          "type": "integer"
        },
        "total_results": {
          "type": "integer"
        }
      },
      "required": [
        "page",
        "results",
        "from",
        "to",
        "total_pages",
        "total_results"
      ]
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "first": {
          "type": "string"
        },
        "last": {
          "type": "string"
        },
        "prev": {
          "type": ["string", "null"]
        },
        "next": {
          "type": ["string", "null"]
        }
      },
      "required": ["first", "last", "prev", "next"]
    },
    "data": {
      "type": "array",
      "items": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "application": {
              "$ref": "#/definitions/ApplicationOverview"
            },
            "property": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "address": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "latitude": {
                      "type": "number"
                    },
                    "longitude": {
                      "type": "number"
                    },
                    "title": {
                      "type": "string"
                    },
                    "singleLine": {
                      "type": "string"
                    },
                    "uprn": {
                      "type": "string"
                    },
                    "town": {
                      "type": "string"
                    },
                    "postcode": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "latitude",
                    "longitude",
                    "title",
                    "singleLine",
                    "uprn",
                    "town",
                    "postcode"
                  ]
                },
                "boundary": {
                  "type": "object",
                  "anyOf": [
                    {
                      "additionalProperties": false,
                      "properties": {
                        "site": {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string"
                            },
                            "geometry": {
                              "type": "object",
                              "properties": {
                                "type": {
                                  "type": "string"
                                },
                                "coordinates": {
                                  "type": "array",
                                  "items": [
                                    {
                                      "type": "array",
                                      "items": [
                                        {
                                          "type": "array",
                                          "items": [
                                            {
                                              "type": "number"
                                            },
                                            {
                                              "type": "number"
                                            }
                                          ]
                                        }
                                      ]
                                    }
                                  ]
                                }
                              },
                              "required": ["type", "coordinates"]
                            },
                            "properties": {
                              "type": ["object", "null"]
                            }
                          },
                          "required": ["type", "geometry", "properties"]
                        }
                      },
                      "required": ["site"]
                    },
                    {
                      "additionalProperties": false,
                      "properties": {
                        "site": {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string"
                            },
                            "features": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string"
                                  },
                                  "geometry": {
                                    "type": "object",
                                    "properties": {
                                      "type": {
                                        "type": "string"
                                      },
                                      "coordinates": {
                                        "type": "array",
                                        "items": [
                                          {
                                            "type": "array",
                                            "items": [
                                              {
                                                "type": "array",
                                                "items": [
                                                  {
                                                    "type": "number"
                                                  },
                                                  {
                                                    "type": "number"
                                                  }
                                                ]
                                              }
                                            ]
                                          }
                                        ]
                                      }
                                    },
                                    "required": ["type", "coordinates"]
                                  },
                                  "properties": {
                                    "type": ["object", "null"]
                                  }
                                },
                                "required": ["type", "geometry", "properties"]
                              }
                            }
                          },
                          "required": ["type", "features"]
                        }
                      },
                      "required": ["site"]
                    }
                  ]
                }
              },
              "required": ["address", "boundary"]
            },
            "proposal": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "description": {
                  "type": "string"
                },
                "reportingType": {
                  "anyOf": [
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "code": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        }
                      },
                      "required": ["code", "description"]
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "ownerIsPlanningAuthority": {
                  "type": "boolean"
                }
              },
              "required": [
                "description",
                "ownerIsPlanningAuthority",
                "reportingType"
              ]
            },
            "applicant": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "address": {
                  "anyOf": [
                    {
                      "$ref": "#/definitions/Address"
                    },
                    { "type": "null" }
                  ]
                },
                "agent": {
                  "anyOf": [
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "address": {
                          "anyOf": [
                            {
                              "$ref": "#/definitions/Address"
                            },
                            { "type": "null" }
                          ]
                        }
                      }
                    },
                    { "type": "null" }
                  ]
                },
                "ownership": {
                  "anyOf": [
                    {
                      "$ref": "#/definitions/Ownership"
                    },
                    { "type": "null" }
                  ]
                },
                "type": {
                  "anyOf": [{ "type": "string" }, { "type": "null" }]
                }
              },
              "required": ["type", "address", "ownership", "agent"]
            },
            "officer": {
              "anyOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": ["string"]
                    }
                  },
                  "required": ["name"]
                },
                {
                  "type": "null"
                }
              ]
            },
            "applicationFee": {}
          },
          "required": ["applicant", "application", "property", "proposal", "applicationFee"]
        }
      ]
    }
  },
  "required": ["metadata", "links", "data"]
}
