{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "application": {
      "$ref": "#/definitions/ApplicationOverview"
    },
    "property": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "latitude": {
              "type": "number"
            },
            "longitude": {
              "type": "number"
            },
            "title": {
              "type": "string"
            },
            "singleLine": {
              "type": "string"
            },
            "uprn": {
              "type": "string"
            },
            "town": {
              "type": "string"
            },
            "postcode": {
              "type": "string"
            }
          },
          "required": [
            "latitude",
            "longitude",
            "title",
            "singleLine",
            "uprn",
            "town",
            "postcode"
          ]
        },
        "boundary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "site": {}
          },
          "required": ["site"]
        }
      },
      "required": ["address", "boundary"]
    },
    "proposal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "reportingType": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "code": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              },
              "required": ["code", "description"]
            },
            {
              "type": "null"
            }
          ]
        },
        "ownerIsPlanningAuthority": {
          "type": "boolean"
        }
      },
      "required": [
        "description",
        "ownerIsPlanningAuthority",
        "reportingType"
      ]
    },
    "applicant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "anyOf": [{ "type": "string" }, { "type": "null" }]
        },
        "address": {
          "anyOf": [
            {
              "$ref": "#/definitions/Address"
            },
            { "type": "null" }
          ]
        },
        "ownership": {
          "anyOf": [
            {
              "$ref": "#/definitions/Ownership"
            },
            { "type": "null" }
          ]
        },
        "agent": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "address": {
                  "anyOf": [
                    {
                      "$ref": "#/definitions/Address"
                    },
                    { "type": "null" }
                  ]
                }
              }
            },
            { "type": "null" }
          ]
        }
      },
      "required": ["type", "address", "ownership", "agent"]
    },
    "officer": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            }
          },
          "required": ["name"]
        },
        {
          "type": "null"
        }
      ]
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "appeal": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "reason": {
              "type": "string"
            },
            "lodgedDate": {
              "type": "string",
              "format": "date"
            },
            "validatedDate": {
              "type": "string",
              "format": "date"
            },
            "startedDate": {
              "type": "string",
              "format": "date"
            },
            "decisionDate": {
              "type": "string",
              "format": "date"
            },
            "decision": {
              "type": "string"
            },
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "referencesInDocument": {
                    "type": "array",
                    "items": {
                      "type": "array"
                    }
                  },
                  "url": {
                    "type": "string"
                  },
                  "type": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        }
                      },
                      "required": ["value", "description"]
                    }
                  },
                  "createdAt": {
                    "format": "date-time",
                    "type": ["string", "null"]
                  },
                  "applicantDescription": {
                    "type": ["string", "null"]
                  },
                  "metadata": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "byteSize": {
                        "type": "integer"
                      },
                      "contentType": {
                        "type": "string"
                      }
                    },
                    "required": ["byteSize", "contentType"]
                  }
                },
                "required": ["name", "url", "type", "metadata"]
              }
            }
          }
        }
      }
    }
  },
  "required": ["application", "property", "proposal", "applicant"]
}
