<%= form_with(model: current_local_authority, url: consultation_path, id: "consultation-form") do |form| %>
  <%= form.govuk_error_summary %>

  <%= form.govuk_fieldset(legend: {text: t(".contact_details")}) do %>
    <%= form.govuk_text_area(:consultation_postal_address, rows: 6, label: {text: t(".postal_address")}) %>
  <% end %>

  <%= form.govuk_submit(t(".submit")) do %>
    <%= back_link %>
  <% end %>
<% end %>
