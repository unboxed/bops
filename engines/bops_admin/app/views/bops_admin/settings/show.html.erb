<% content_for :page_title do %>
  <%= t(".settings") %> - <%= t("page_title") %>
<% end %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <h1 class="govuk-heading-l"><%= t(".settings") %></h1>

    <%= govuk_summary_list(classes: "govuk-summary-list--no-border") do |summary_list|
          summary_list.with_row do |row|
            row.with_key { t(".determination_period") }
            row.with_value { t(".determination_period_including_bank_holidays", count:"12") if true }
            row.with_action(text: t(".change"), href: url_for([:edit, :setting, :determination_period]), visually_hidden_text: t(".determination_period"))
          end
        end %>
  </div>
</div>
