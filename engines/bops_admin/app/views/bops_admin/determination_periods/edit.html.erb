<% content_for :page_title do %>
  <%= t(".determination_period") %> - <%= t("page_title") %>
<% end %>

<% add_parent_breadcrumb_link "Home", root_path %>

<% content_for :title, t(".determination_period") %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <%= form_with model: @application_type, url: [:setting, :determination_period] do |form| %>

      <%= form.govuk_text_field :determination_period_days, width: 5,
            label: {text: t(".set_determination_period"), size: "l"},
            hint: {text: t(".hint")},
            suffix_text: t(".days") %>

      <%= form.govuk_submit(t(".continue")) do %>
        <%= govuk_button_link_to t("back"), @application_type, secondary: true %>
      <% end %>
    <% end %>
  </div>
</div>
