<%= render "task_header", task: @task %>

<%= render(
  AccordionComponent.new(
    planning_application: @planning_application,
    sections: %w[constraints considerations]
  )
) %>

<%= render(ReviewerCommentComponent.new(comment: @form.condition_set.current_review)) %>

<% if @form.conditions.any? %>
  <h2 class="govuk-!-margin-bottom-0">Add, edit and sort pre-commencement conditions</h2>
  <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
  <ol data-controller="sortable" id="conditions-list" class="govuk-list sortable-list">
    <% @form.conditions.each.with_index(1) do |condition, position| %>
      <%= render(Sortable::ListItemComponent.new(
            record: condition,
            position: position,
            record_class: "condition",
            record_controller: "pre-commencement-conditions",
            record_sortable_url: planning_application_assessment_pre_commencement_condition_position_path(@planning_application, condition),
            edit_record_url: @form.edit_condition_url(condition),
            remove_record_url: @form.remove_condition_url(condition),
            cancel_record_url: @form.cancel_condition_url(condition),
            current_request: condition.current_validation_request
          )) %>
    <% end %>
  </ol>

  <p class="govuk-hint">
    Drag and drop conditions to change the order that they appear in the decision notice.
  </p>
<% end %>

<%= govuk_details(summary_text: "Add new pre-commencement condition",
      open: @form.conditions.empty?,
      classes: "govuk-details--borderless govuk-!-margin-top-6") do %>
  <h3>Add a new pre-commencement condition</h3>
  <%= form_with model: @form, url: @form.url do |form| %>
    <%= form.govuk_error_summary %>
    <%= form.govuk_text_field :title, label: {text: "Enter title"} %>
    <%= form.govuk_text_area :text, rows: 5, label: {text: "Enter condition"} %>
    <%= form.govuk_text_area :reason, rows: 5, label: {text: "Enter reason"} %>
    <%= form.govuk_task_button "Add pre-commencement condition", action: "add_condition", secondary: true %>
  <% end %>
<% end %>

<% if @form.waiting_for_applicant? %>
  <p>Waiting for the applicant to respond to the requests.</p>
<% end %>

<div class="govuk-button-group">
  <% if @form.all_approved? %>
    <% unless @form.condition_set.current_review&.complete? %>
      <%= form_with model: @form, url: @form.url do |form| %>
        <%= form.govuk_task_button "Save and mark as complete" %>
      <% end %>
    <% end %>
  <% elsif @form.pending_requests? %>
    <%= form_with model: @form, url: @form.url do |form| %>
      <%= form.govuk_task_button "Confirm and send to applicant", action: "confirm_and_send" %>
      <%= form.govuk_task_button "Save and come back later", action: "save_draft", secondary: true %>
    <% end %>
  <% else %>
    <%= form_with model: @form, url: @form.url do |form| %>
      <%= form.govuk_task_button "Save and mark as complete" %>
      <%= form.govuk_task_button "Save and come back later", action: "save_draft", secondary: true %>
    <% end %>
  <% end %>
</div>
