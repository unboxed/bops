<%= render "task_header", task: @task %>

<%= render(ReviewerCommentComponent.new(comment: @form.consideration_set.current_review)) %>

<h2 class="govuk-!-margin-bottom-0">Add, edit and sort considerations</h2>
<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

<% if @form.considerations.any? %>
  <ol data-controller="sortable" class="govuk-list sortable-list">
    <%= render partial: "planning_applications/assessment/considerations/consideration",
          collection: @form.considerations,
          locals: {
            editable: true,
            task_slug: @task.full_slug,
            return_to: @task.url
          } %>
  </ol>
  <p><%= t(".drag_and_drop") %></p>
<% else %>
  <p>
    <strong>No considerations added yet</strong>
  </p>
  <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
<% end %>

<%= govuk_details(summary_text: "Add new consideration", open: @form.considerations.none? || @form.consideration.errors.any?) do %>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds" data-controller="consideration-form">
      <%= form_with model: @form.consideration, url: @form.url do |consideration_form| %>
        <%= consideration_form.govuk_error_summary %>
        <%= consideration_form.govuk_fieldset legend: {text: "Add a new consideration"} do %>
          <%= consideration_form.govuk_collection_select :policy_area,
                current_local_authority.policy_areas.menu,
                :last, :last, options: {include_blank: true},
                label: {text: "Enter policy area"},
                data: {consideration_form_target: "policyAreaSelect"} %>

          <div class="govuk-form-group">
            <%= consideration_form.govuk_text_field :policy_references,
                  label: {text: "Enter policy references"},
                  hint: {text: "Start typing to find an existing policy reference"},
                  form_group: {class: "govuk-!-margin-bottom-0", data: {consideration_form_target: "policyReferencesContainer"}},
                  data: {consideration_form_target: "policyReferencesInput"} %>

            <ul class="govuk-list editable-list" data-consideration-form-target="policyReferences">
              <%= consideration_form.fields :policy_references do |fields| %>
                <li>
                  <%= fields.hidden_field :code %>
                  <%= fields.hidden_field :description %>
                  <%= fields.hidden_field :url %>
                  <span><%= fields.object.code %> - <%= fields.object.description %></span>
                  <button type="button" class="button-as-link" data-action="click->consideration-form#removePolicyReference">Remove</button>
                </li>
              <% end %>
            </ul>

            <template data-consideration-form-target="policyReferenceTemplate">
              <li>
                <input type="hidden" name="code" value="">
                <input type="hidden" name="description" value="">
                <input type="hidden" name="url" value="">
                <span>Code - Description</span>
                <button type="button" class="button-as-link" data-action="click->consideration-form#removePolicyReference">Remove</button>
              </li>
            </template>
          </div>

          <div class="govuk-form-group">
            <%= consideration_form.govuk_text_field :policy_guidance,
                  label: {text: "Enter policy guidance (optional)"},
                  hint: {text: "Start typing to find existing policy guidance"},
                  form_group: {class: "govuk-!-margin-bottom-0", data: {consideration_form_target: "policyGuidanceContainer"}},
                  data: {consideration_form_target: "policyGuidanceInput"} %>

            <ul class="govuk-list editable-list" data-consideration-form-target="policyGuidance">
              <%= consideration_form.fields :policy_guidance do |fields| %>
                <li>
                  <%= fields.hidden_field :description %>
                  <%= fields.hidden_field :url %>
                  <span><%= fields.object.description %></span>
                  <button type="button" class="button-as-link" data-action="click->consideration-form#removePolicyGuidance">Remove</button>
                </li>
              <% end %>
            </ul>

            <template data-consideration-form-target="policyGuidanceTemplate">
              <li>
                <input type="hidden" name="description" value="">
                <input type="hidden" name="url" value="">
                <span>Description</span>
                <button type="button" class="button-as-link" data-action="click->consideration-form#removePolicyGuidance">Remove</button>
              </li>
            </template>
          </div>

          <%= consideration_form.govuk_text_area :assessment, label: {text: "Enter assessment"}, rows: 5 %>
          <%= consideration_form.govuk_text_area :conclusion, label: {text: "Enter conclusion"}, rows: 3 %>
        <% end %>

        <%= hidden_field_tag :task_action, "add_consideration" %>
        <%= consideration_form.govuk_submit "Add consideration", secondary: true, class: "govuk-!-margin-bottom-2" %>
      <% end %>
    </div>
  </div>
<% end %>

<%= govuk_section_break(visible: true, size: "xl") %>

<%= form_with model: @form, url: @form.url do |form| %>
  <%= render "task_submit_buttons", form: form %>
<% end %>
