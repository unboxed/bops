<%= govuk_summary_card(title: "Site notice #{index + 1}", html_attributes: {class: "govuk-!-margin-top-6"}) do |card| %>
    <% unless site_notice.displayed_at? %>
      <% card.with_action do %>
        <%= form_with model: @form, url: @form.confirmation_request_url(site_notice) do |form| %>
          <%= form.govuk_task_button_link "Send reminder", action: "send_confirmation_request" %>
        <% end %>
      <% end %>
  <% end %>
  <% card.with_summary_list do |summary_list| %>
    <% summary_list.with_row do |row| %>
      <% row.with_key { "Quantity" } %>
      <% row.with_value { site_notice.quantity.to_s } %>
    <% end %>

    <% summary_list.with_row do |row| %>
      <% row.with_key { "Display instructions" } %>
      <% row.with_value { site_notice.location_instructions.presence || "None" } %>
    <% end %>

    <% summary_list.with_row do |row| %>
      <% row.with_key { "Arranged via" } %>
      <% row.with_value { site_notice.audits.find_by(activity_type: "site_notice_created")&.audit_comment } %>
    <% end %>

    <% summary_list.with_row do |row| %>
      <% row.with_key { "PDF" } %>
      <% row.with_value do %>
        <%= stimulus_tag("site-notice", values: {context: site_notice.pdf_context}) do %>
          <%= govuk_link_to "Download site notice PDF", "#", data: {action: "click->site-notice#downloadPdf"}, no_visited_state: true %>
          <div style="width: 0px; height: 0px; overflow: hidden;" aria-hidden="true">
            <% if current_local_authority.site_notice.logo.present? %>
              <%= tag.img \
                    src: data_uri("image/svg+xml", current_local_authority.site_notice.logo),
                    style: "height: 120px;",
                    data: {site_notice_target: "logo"} %>
            <% end %>
          </div>

          <div style="width: 0px; height: 0px; overflow: hidden;" aria-hidden="true">
            <%= tag.my_map \
                  osProxyEndpoint: applicants_os_proxy_url,
                  latitude: @planning_application.latitude,
                  longitude: @planning_application.longitude,
                  geojsonData: @planning_application.boundary_geojson.to_json,
                  staticMode: true, hideResetControl: true,
                  style: "width: 550px; height: 400px;",
                  data: {site_notice_target: "map"} %>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <% summary_list.with_row do |row| %>
      <% row.with_key { "Created" } %>
      <% row.with_value { site_notice.created_at.to_date.to_fs } %>
    <% end %>

    <% summary_list.with_row do |row| %>
      <% row.with_key { "Status" } %>
      <% row.with_value do %>
        <% if site_notice.displayed_at? && site_notice.documents.any? %>
          <strong class="govuk-tag govuk-tag--green">Displayed</strong>
        <% else %>
          <strong class="govuk-tag govuk-tag--blue">Sent</strong>
        <% end %>
      <% end %>
    <% end %>

    <% summary_list.with_row do |row| %>
      <% row.with_key(classes: "govuk-summary-list__key") { "Display details" } %>
      <% row.with_value do %>
        <% if site_notice.displayed_at? && site_notice.documents.any? %>
          <% site_notice.documents.each do |document| %>
            <div class="display-flex govuk-!-margin-bottom-2">
              <div class="govuk-!-margin-right-3">
                <%= document_thumbnail_link document, thumbnail_args: {resize: "300x212"} %>
              </div>
              <div>
                <p class="govuk-!-margin-bottom-1"><%= truncate(document.name.to_s, length: 50) %></p>
                <p class="govuk-!-margin-bottom-1">Displayed: <%= site_notice.displayed_at.to_date.to_fs %></p>
                <p class="govuk-!-margin-bottom-1">Expires: <%= site_notice.expiry_date&.to_fs %></p>
                <%= govuk_link_to "Edit display details", @form.edit_site_notice_url(site_notice), no_visited_state: true %>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= govuk_link_to "Confirm display", @form.edit_site_notice_url(site_notice) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
