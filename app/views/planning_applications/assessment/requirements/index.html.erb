<% content_for :page_title do %>
  Check and add requirements - <%= t("page_title") %>
<% end %>

<%= render(
      partial: "shared/assessment_task_breadcrumbs",
      locals: {planning_application: @planning_application}
    ) %>

<% content_for :title, "Check and add requirements" %>

<%= render(
      partial: "shared/proposal_header",
      locals: {heading: "Check and add requirements"}
    ) %>

<hr>

  <%= @categories.each do |category| %>
      <div class="govuk-summary-card">
          <div class="govuk-summary-card__title-wrapper">
              <h2 class="govuk-summary-card__title">
                  <%= category.humanize %>
              </h2>
          </div>
              <%= render("table", requirements: @planning_application.requirements.where(category: category)) %>
      </div>
  <% end %>


<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        <p class="govuk-body">
           This section is to select requirements to add to the list.
        </p>
        <div class="govuk-tabs" data-module="govuk-tabs">
          <%= form_tag(planning_application_assessment_requirements_path, method: "post") do %>
            <%= govuk_tabs do |tabs| %>
                <%= @categories.each do |category| %>
                  <% tabs.with_tab(label: category.humanize) do %>
                      <%= render("list", requirements: @requirements.where(category: category), category: category) %>
                  <% end %>
                <% end %>
            <% end %>
            <%= submit_tag("Generate list", class: "govuk-button" )  %>
          <% end %>
        </div>

    <div class="govuk-button-group">
      <%# <%= govuk_button_link_to "Generate list of requirements", add_requirements_planning_application_path(@planning_application)  %> %>
      <%= back_link %>
    </div>
</div>
