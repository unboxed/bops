<%= render "task_header", task: @task, heading: "View consultee response" %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <%= render ConsulteeSummaryComponent.new(consultee: @consultee) %>
    <%= render BopsCore::ConsulteeResponseListComponent.new(
          responses: @consultee.responses,
          redact_and_publish: true,
          task: @task
        ) %>

    <div class="govuk-button-group govuk-!-margin-top-5">
      <%= govuk_button_link_to "Back", @task.url, secondary: true %>
    </div>
  </div>
</div>
